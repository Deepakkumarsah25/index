                function handwritingToText() { window.location.href = "/handwritingtotext"; }

                // ===== PARTICLES (rhParticles) =====
                (function() {
                    var c = document.getElementById('rhParticles');
                    if (!c) return;
                    var cols = ['#4da8da', '#ff6b35', '#fff', '#a8dcf5', '#ffb28b'];
                    for (var i = 0; i < 32; i++) {
                        var p = document.createElement('div');
                        p.className = 'rh-p';
                        var s = Math.random() * 5 + 2,
                            col = cols[Math.floor(Math.random() * cols.length)];
                        p.style.cssText = 'width:' + s + 'px;height:' + s + 'px;background:' + col +
                            ';left:' + Math.random() * 100 + '%;bottom:-20px' +
                            ';animation-duration:' + (Math.random() * 10 + 8) + 's' +
                            ';animation-delay:' + (Math.random() * 15) + 's' +
                            ';box-shadow:0 0 ' + (s * 3) + 'px ' + col + ';opacity:0';
                        c.appendChild(p);
                    }
                })();

                // ===== CANVAS NETWORK =====
                const canvas = document.getElementById('bg');
                if (canvas) {
                    const ctx = canvas.getContext('2d');
                    let W, H, pts = [];

                    function resize() {
                        W = canvas.width = canvas.offsetWidth;
                        H = canvas.height = canvas.offsetHeight;
                    }
                    resize();
                    window.addEventListener('resize', () => {
                        resize();
                        pts = [];
                        for (let i = 0; i < 120; i++) pts.push(mkPt());
                    });

                    function mkPt() {
                        return {
                            x: Math.random() * W,
                            y: Math.random() * H,
                            vx: (Math.random() - .5) * 2.2,
                            vy: (Math.random() - .5) * 2.2,
                            r: Math.random() * 2 + .8,
                            pulse: Math.random() * Math.PI * 2
                        };
                    }
                    for (let i = 0; i < 120; i++) pts.push(mkPt());

                    let hexPhase = 0;

                    function drawHexes() {
                        hexPhase += 0.018;
                        for (let i = 0; i < 7; i++) {
                            const cx = W * .05 + i * (W * .16);
                            const cy = H * .35 + Math.sin(hexPhase + i * 0.9) * H * .18;
                            const r = 55 + Math.cos(hexPhase * 1.3 + i) * 20;
                            ctx.beginPath();
                            for (let a = 0; a < 6; a++) {
                                const ang = a * Math.PI / 3 - Math.PI / 6;
                                a === 0 ?
                                    ctx.moveTo(cx + r * Math.cos(ang), cy + r * Math.sin(ang)) :
                                    ctx.lineTo(cx + r * Math.cos(ang), cy + r * Math.sin(ang));
                            }
                            ctx.closePath();
                            const alpha = 0.04 + Math.abs(Math.sin(hexPhase + i)) * 0.06;
                            ctx.fillStyle = `rgba(30,200,168,${alpha})`;
                            ctx.strokeStyle = `rgba(30,200,168,${alpha * 2})`;
                            ctx.lineWidth = .6;
                            ctx.fill();
                            ctx.stroke();
                        }
                    }

                    function drawNet() {
                        ctx.clearRect(0, 0, W, H);
                        drawHexes();

                        for (let i = 0; i < pts.length; i++) {
                            const p = pts[i];
                            p.pulse += 0.06;

                            for (let j = i + 1; j < pts.length; j++) {
                                const q = pts[j];
                                const dx = p.x - q.x,
                                    dy = p.y - q.y;
                                const d = Math.sqrt(dx * dx + dy * dy);
                                if (d < 120) {
                                    const a = (1 - d / 120) * .55;
                                    ctx.strokeStyle = `rgba(30,200,168,${a})`;
                                    ctx.lineWidth = .6;
                                    ctx.beginPath();
                                    ctx.moveTo(p.x, p.y);
                                    ctx.lineTo(q.x, q.y);
                                    ctx.stroke();
                                }
                            }

                            const pr = p.r + Math.sin(p.pulse) * .6;
                            ctx.beginPath();
                            ctx.arc(p.x, p.y, pr, 0, Math.PI * 2);
                            ctx.fillStyle = 'rgba(30,200,168,0.75)';
                            ctx.fill();

                            p.x += p.vx;
                            p.y += p.vy;
                            if (p.x < 0 || p.x > W) p.vx *= -1;
                            if (p.y < 0 || p.y > H) p.vy *= -1;
                        }

                        requestAnimationFrame(drawNet);
                    }
                    drawNet();
                }

                // ===== GSAP ANIMATIONS (safe) =====
                if (typeof gsap !== 'undefined') {
                    // Animate feature cards with stagger
                    gsap.from('.feature-card', {
                        opacity: 0,
                        y: 40,
                        duration: 0.7,
                        stagger: 0.1,
                        ease: 'power3.out',
                        scrollTrigger: {
                            trigger: '.feature-grid',
                            start: 'top 85%',
                            toggleActions: 'play none none none'
                        }
                    });

                    // Animate flip cards on scroll
                    gsap.from('.flip-card', {
                        opacity: 0,
                        y: 50,
                        duration: 0.7,
                        stagger: 0.12,
                        ease: 'power3.out',
                        scrollTrigger: {
                            trigger: '.tools-grid',
                            start: 'top 88%',
                            toggleActions: 'play none none none'
                        }
                    });

                    // Animate tools & technology section
                    gsap.from('.tools-and-technology-section .section-title-wrap', {
                        opacity: 0,
                        x: -30,
                        duration: 0.7,
                        ease: 'power3.out',
                        scrollTrigger: {
                            trigger: '.tools-and-technology-section',
                            start: 'top 88%',
                            toggleActions: 'play none none none'
                        }
                    });

                    gsap.from('.tools-and-technology-section .technologies-items', {
                        opacity: 0,
                        x: 40,
                        duration: 0.8,
                        ease: 'power3.out',
                        scrollTrigger: {
                            trigger: '.tools-and-technology-section',
                            start: 'top 88%',
                            toggleActions: 'play none none none'
                        }
                    });

                    // Also handle any existing .card animations if needed
                    gsap.set('.card', { y: 30 });
                    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
                    tl.from('#eyebrow', { y: -15, opacity: 0, duration: .4, delay: .1 })
                        .from('#headline', { y: 20, opacity: 0, duration: .6 }, '-=.2')
                        .from('#sub', { y: 15, opacity: 0, duration: .5 }, '-=.3')
                        .to('.card', {
                            opacity: 1,
                            y: 0,
                            duration: .5,
                            stagger: .08,
                            ease: 'back.out(1.4)'
                        }, '-=.2');

                    gsap.to('.icon-wrap', {
                        y: -4,
                        duration: 1.4,
                        ease: 'sine.inOut',
                        yoyo: true,
                        repeat: -1,
                        stagger: { each: .3 }
                    });

                    document.querySelectorAll('.card').forEach(c => {
                        c.addEventListener('mouseenter', () => {
                            gsap.to(c.querySelector('.icon-wrap'), {
                                scale: 1.12,
                                duration: .25,
                                ease: 'power2.out',
                                boxShadow: '0 6px 28px rgba(30,200,168,0.5)'
                            });
                            gsap.to(c.querySelector('.card-title'), { color: '#1EC8A8', duration: .2 });
                        });
                        c.addEventListener('mouseleave', () => {
                            gsap.to(c.querySelector('.icon-wrap'), {
                                scale: 1,
                                duration: .3,
                                ease: 'power2.inOut'
                            });
                            gsap.to(c.querySelector('.card-title'), { color: '#ffffff', duration: .2 });
                        });
                    });
                }

                // ===== TOOLS SCROLL =====
                function tools() {
                    const section = document.getElementById("tools-section");
                    if (section) {
                        const yOffset = -120;
                        const y = section.getBoundingClientRect().top + window.pageYOffset + yOffset;
                        window.scrollTo({ top: y, behavior: "smooth" });
                    }
                }

                // ===== RESIZE SAFETY =====
                window.addEventListener('resize', function() {
                    const banner = document.querySelector('.bada-hero');
                    if (banner) {
                        banner.style.maxWidth = '100vw';
                    }
                });
            </script>

            <!-- GSAP CDN (safe fallback) -->
            <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js">
            </script>
            <!-- ScrollTrigger plugin for card animations -->
            <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js">
            </script>
            <script>
                // Register ScrollTrigger plugin
                if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
                    gsap.registerPlugin(ScrollTrigger);
                }
            </script>

</body>

</html>