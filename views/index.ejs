            <script>
                // ============================================================
                // FLIP CARD — only the clicked card flips, buttons are safe
                // ============================================================
                function toggleFlip(card, event) {
                    // If click came from a button or close-hint, ignore
                    if (event && event.target) {
                        if (event.target.closest('.tool-btn') ||
                            event.target.closest('.close-hint') ||
                            event.target.closest('.back-header') ||
                            event.target.closest('.tools-list')) {
                            return;
                        }
                    }
                    if (!card) return;
                    // Toggle flipped state on this card only
                    card.classList.toggle('flipped');
                }

                // Close flipped cards when clicking outside (anywhere on document)
                document.addEventListener('click', function(e) {
                    const cards = document.querySelectorAll('.flip-card.flipped');
                    cards.forEach(card => {
                        // If click is not inside this card, close it
                        if (!card.contains(e.target)) {
                            card.classList.remove('flipped');
                        }
                    });
                });

                // Also close flipped cards on Escape key
                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') {
                        document.querySelectorAll('.flip-card.flipped').forEach(c => c.classList.remove('flipped'));
                    }
                });

                // ============================================================
                // RIPPLE EFFECT on tool buttons (professional click feedback)
                // ============================================================
                document.addEventListener('click', function(e) {
                    const btn = e.target.closest('.tool-btn');
                    if (!btn) return;
                    // Create ripple element
                    const ripple = document.createElement('span');
                    ripple.className = 'ripple';
                    const rect = btn.getBoundingClientRect();
                    const size = Math.max(rect.width, rect.height);
                    ripple.style.width = ripple.style.height = size + 'px';
                    ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
                    ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
                    btn.style.position = 'relative';
                    btn.style.overflow = 'hidden';
                    btn.appendChild(ripple);
                    // Remove after animation
                    setTimeout(() => ripple.remove(), 500);
                });

                // ============================================================
                // NAVIGATION HELPERS
                // ============================================================
                function workshop() {
                    window.open("workshop/form.html", "_self");
