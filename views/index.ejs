                <!-- ============================================================
                ===== TOOLS SECTION — 3D FLIP CARDS (ENHANCED) =====
                ============================================================ -->
                <section class="tools-section" id="tools-section">
                    <div class="section-label">
                        <span class="dot"></span> Free Tools
                    </div>
                    <h2 class="section-title">
                        Powerful <span class="accent">Toolkit</span> at Your Fingertips
                    </h2>
                    <p class="section-desc">
                        Click any card to flip it 360° and explore all the tools inside. Each button is ready to use.
                    </p>

                    <div class="tools-grid">

                        <!-- ===== CARD 1: Image Tools ===== -->
                        <div class="flip-card" data-category="image">
                            <div class="flip-card-inner">
                                <!-- FRONT -->
                                <div class="flip-card-front" onclick="toggleFlip(this.closest('.flip-card'), event)">
                                    <div class="tool-icon">
                                        <i class="fas fa-image"></i>
                                    </div>
                                    <h3>Image Tools</h3>
                                    <p>Convert, compress, resize, crop &amp; more</p>
                                    <div class="flip-hint">
                                        <i class="fas fa-rotate-right"></i> Click to flip
                                    </div>
                                </div>
                                <!-- BACK -->
                                <div class="flip-card-back">
                                    <div class="back-header">
                                        <i class="fas fa-image"></i>
                                        <h4>Image Tools</h4>
                                        <span class="badge-count">7 tools</span>
                                    </div>
                                    <div class="tools-list">
                                        <button class="tool-btn" onclick="event.stopPropagation();convertimage()">
                                            <span class="btn-label"><i class="fas fa-exchange-alt"></i><span class="btn-text">Convert Image</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                        <button class="tool-btn" onclick="event.stopPropagation();compress()">
                                            <span class="btn-label"><i class="fas fa-compress-alt"></i><span class="btn-text">Compress Image</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                        <button class="tool-btn" onclick="event.stopPropagation();resize()">
                                            <span class="btn-label"><i class="fas fa-expand-arrows-alt"></i><span class="btn-text">Resize Image</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                        <button class="tool-btn" onclick="event.stopPropagation();convert()">
                                            <span class="btn-label"><i class="fas fa-file-pdf"></i><span class="btn-text">Image to PDF</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                        <button class="tool-btn" onclick="event.stopPropagation();crop()">
                                            <span class="btn-label"><i class="fas fa-crop-alt"></i><span class="btn-text">Crop Image</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                        <button class="tool-btn" onclick="event.stopPropagation();image()">
                                            <span class="btn-label"><i class="fas fa-eye"></i><span class="btn-text">Image to Text (OCR)</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                        <button class="tool-btn" onclick="event.stopPropagation();merge()">
                                            <span class="btn-label"><i class="fas fa-object-group"></i><span class="btn-text">Merge Images</span></span>
                                            <span class="btn-arrow"><i class="fas fa-arrow-right"></i></span>
                                        </button>
                                    </div>
                                    <div class="close-hint" onclick="this.closest('.flip-card').classList.remove('flipped')">
                                        <i class="fas fa-rotate-left"></i> Click to flip back
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== CARD 2: PDF Tools ===== -->
                        <div class="flip-card" data-category="pdf">
